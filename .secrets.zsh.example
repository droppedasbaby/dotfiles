# Machine-local secrets and env vars — not checked into git.
# Copy this file to ~/.dotfiles/.secrets and fill in your values.
# Sourced by .zshrc at the end of shell init.

# Root of all your project directories — required by ds, wt, sync-repos
export DEV_DIR="$HOME/dev"

# Prefix auto-prepended to bare ticket IDs in wt
# e.g. `wt my-repo PROJ-123` → branch YOU/PROJ-123
# Required by wt
export WORKTREE_PREFIX="YOU"
