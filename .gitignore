.DS_Store

# Secrets
.secrets.zsh

# tmux plugins (managed by TPM)
.config/tmux/plugins/
.tmux/plugins/

# raycast extensions (managed by Raycast)
.config/raycast/extensions/

# gh CLI auth (user-specific, setup.sh handles login)
.config/gh/hosts.yml

# local Claude settings
.claude/settings.local.json

# lock files
Brewfile.lock.json

# local runtime logs
.nvimlog

# machine-specific dev config lives outside dotfiles (for example ~/dev/configs)

# machine-local secrets (tokens, API keys, env vars — sourced by .zshrc)
.secrets.zsh
